-- @uniquadev CONVERTER -> Dynamic UI Library (Dictionary Format + Paragraphs)
local Library = {}
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

function Library:CreateWindow(options)
    local Window = {}
    local windowTitle = options.Title or "UI Library"
    
    -- Main GUI
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "CustomUILibrary"
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.Parent = PlayerGui -- Use CoreGui if running as an exploit script

    local SettingsScreen = Instance.new("Frame")
    SettingsScreen.Name = "SettingsScreen"
    SettingsScreen.Size = UDim2.new(1, -20, 1, -20)
    SettingsScreen.Position = UDim2.new(0.5, 0, 0.5, 0)
    SettingsScreen.AnchorPoint = Vector2.new(0.5, 0.5)
    SettingsScreen.BackgroundTransparency = 1
    SettingsScreen.Parent = ScreenGui

    local SettingsContainer = Instance.new("ImageLabel")
    SettingsContainer.Name = "SettingsContainer"
    SettingsContainer.Size = UDim2.new(0.7, 0, 0.75, 0)
    SettingsContainer.Position = UDim2.new(0.5, 0, 0.5, 0)
    SettingsContainer.AnchorPoint = Vector2.new(0.5, 0.5)
    SettingsContainer.BackgroundTransparency = 1
    SettingsContainer.Image = "rbxassetid://123911976725450"
    SettingsContainer.Parent = SettingsScreen

    local UIAspectRatioConstraint = Instance.new("UIAspectRatioConstraint")
    UIAspectRatioConstraint.AspectRatio = 1.54
    UIAspectRatioConstraint.Parent = SettingsContainer

    local Contents = Instance.new("ScrollingFrame")
    Contents.Name = "Contents"
    Contents.Size = UDim2.new(0.95, 0, 0.935, 0)
    Contents.Position = UDim2.new(0.5, 0, 0.035, 0)
    Contents.AnchorPoint = Vector2.new(0.5, 0)
    Contents.BackgroundTransparency = 1
    Contents.BorderSizePixel = 0
    Contents.ScrollBarThickness = 8
    Contents.Active = true
    Contents.VerticalScrollBarPosition = Enum.VerticalScrollBarPosition.Left
    Contents.VerticalScrollBarInset = Enum.ScrollBarInset.Always
    Contents.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Contents.CanvasSize = UDim2.new(0, 0, 0, 0)
    Contents.TopImage = "rbxassetid://18912599863"
    Contents.MidImage = "rbxassetid://18912597717"
    Contents.BottomImage = "rbxassetid://18912598903"
    Contents.Parent = SettingsContainer

    local UIPadding = Instance.new("UIPadding")
    UIPadding.PaddingLeft = UDim.new(0.025, 0)
    UIPadding.Parent = Contents

    local UIListLayout = Instance.new("UIListLayout")
    UIListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    UIListLayout.Padding = UDim.new(0, 10)
    UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    UIListLayout.Parent = Contents

    local CustomFont = Font.new("rbxasset://fonts/families/AccanthisADFStd.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)

    -- Base Function to generate the standard Setting layout
    local function CreateBaseSetting(name, desc)
        local SettingFrame = Instance.new("Frame")
        SettingFrame.Name = name:gsub("%s+", "")
        SettingFrame.Size = UDim2.new(0.7, 0, 0.075, 25)
        SettingFrame.BackgroundTransparency = 1
        SettingFrame.BorderSizePixel = 0

        local SettingName = Instance.new("TextLabel")
        SettingName.Name = "SettingName"
        SettingName.Size = UDim2.new(0.6, 0, 0.65, 0)
        SettingName.BackgroundTransparency = 1
        SettingName.FontFace = CustomFont
        SettingName.TextColor3 = Color3.fromRGB(255, 255, 255)
        SettingName.TextScaled = true
        SettingName.TextXAlignment = Enum.TextXAlignment.Left
        SettingName.RichText = true
        SettingName.Text = name
        SettingName.Parent = SettingFrame

        local SettingDesc = Instance.new("TextLabel")
        SettingDesc.Name = "SettingDesc"
        SettingDesc.Size = UDim2.new(0.7, 0, 0.4, 0)
        SettingDesc.Position = UDim2.new(0, 0, 1, 0)
        SettingDesc.AnchorPoint = Vector2.new(0, 1)
        SettingDesc.BackgroundTransparency = 1
        SettingDesc.FontFace = CustomFont
        SettingDesc.TextColor3 = Color3.fromRGB(255, 255, 255)
        SettingDesc.TextScaled = true
        SettingDesc.TextXAlignment = Enum.TextXAlignment.Left
        SettingDesc.RichText = true
        SettingDesc.Text = desc
        SettingDesc.Parent = SettingFrame

        local Reset = Instance.new("ImageButton")
        Reset.Name = "Reset"
        Reset.Size = UDim2.new(0.125, 0, 1, 0)
        Reset.Position = UDim2.new(-0.1, 0, 0.5, 0)
        Reset.AnchorPoint = Vector2.new(0.5, 0.5)
        Reset.BackgroundTransparency = 1
        Reset.Image = "rbxassetid://89008322108617"
        Reset.Parent = SettingFrame

        Instance.new("UIAspectRatioConstraint", Reset)

        return SettingFrame
    end

    -- Tab System
    function Window:CreateTab(tabOptions)
        local Tab = {}
        local title = tabOptions.Title or "New Tab"

        -- Creates the Category Header
        local Category = Instance.new("ImageLabel")
        Category.Name = title
        Category.Size = UDim2.new(0.99, 0, 0, 60)
        Category.BackgroundTransparency = 1
        Category.Image = "rbxassetid://19000746528"
        Category.Parent = Contents

        local HeaderTitle = Instance.new("TextLabel")
        HeaderTitle.Name = "Title"
        HeaderTitle.Size = UDim2.new(1, 0, 0.65, 0)
        HeaderTitle.Position = UDim2.new(0.5, 0, 0.5, 0)
        HeaderTitle.AnchorPoint = Vector2.new(0.5, 0.5)
        HeaderTitle.BackgroundTransparency = 1
        HeaderTitle.FontFace = CustomFont
        HeaderTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
        HeaderTitle.TextSize = 36
        HeaderTitle.RichText = true
        HeaderTitle.Text = title
        HeaderTitle.Parent = Category

        -- Paragraph Method (Header + Line + Text Block)
        function Tab:Paragraph(opt)
            local titleText = opt.Title or "Header"
            local contentText = opt.Content or "Text goes here"

            local ParagraphGroup = Instance.new("Frame")
            ParagraphGroup.Name = "ParagraphGroup"
            ParagraphGroup.Size = UDim2.new(0.9, 0, 0, 0)
            ParagraphGroup.BackgroundTransparency = 1
            ParagraphGroup.AutomaticSize = Enum.AutomaticSize.Y
            ParagraphGroup.Parent = Contents

            local ParaLayout = Instance.new("UIListLayout")
            ParaLayout.SortOrder = Enum.SortOrder.LayoutOrder
            ParaLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
            ParaLayout.Padding = UDim.new(0, 8)
            ParaLayout.Parent = ParagraphGroup

            local BoldFont = Font.new("rbxasset://fonts/families/AccanthisADFStd.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)

            local TitleLabel = Instance.new("TextLabel")
            TitleLabel.Name = "Header"
            TitleLabel.Size = UDim2.new(1, 0, 0, 30)
            TitleLabel.BackgroundTransparency = 1
            TitleLabel.FontFace = BoldFont
            TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            TitleLabel.TextScaled = true
            TitleLabel.Text = titleText
            TitleLabel.LayoutOrder = 1
            TitleLabel.Parent = ParagraphGroup

            local SeparatorContainer = Instance.new("Frame")
            SeparatorContainer.Name = "SeparatorContainer"
            SeparatorContainer.Size = UDim2.new(1, 0, 0, 5)
            SeparatorContainer.BackgroundTransparency = 1
            SeparatorContainer.LayoutOrder = 2
            SeparatorContainer.Parent = ParagraphGroup

            local Line = Instance.new("Frame")
            Line.Name = "MainLine"
            Line.Size = UDim2.new(0.85, 0, 1, 0)
            Line.Position = UDim2.new(0.5, 0, 0, 0)
            Line.AnchorPoint = Vector2.new(0.5, 0)
            Line.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Line.BorderSizePixel = 0
            Line.Parent = SeparatorContainer

            local ContentLabel = Instance.new("TextLabel")
            ContentLabel.Name = "Content"
            ContentLabel.Size = UDim2.new(0.95, 0, 0, 0)
            ContentLabel.BackgroundTransparency = 1
            ContentLabel.FontFace = CustomFont
            ContentLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            ContentLabel.TextSize = 20
            ContentLabel.TextXAlignment = Enum.TextXAlignment.Left
            ContentLabel.TextYAlignment = Enum.TextYAlignment.Top
            ContentLabel.TextWrapped = true
            ContentLabel.RichText = true
            ContentLabel.Text = contentText
            ContentLabel.AutomaticSize = Enum.AutomaticSize.Y
            ContentLabel.LayoutOrder = 3
            ContentLabel.Parent = ParagraphGroup
        end

        function Tab:Toggle(opt)
            local name = opt.Title or "Toggle"
            local desc = opt.Description or ""
            local default = opt.Default or false
            local callback = opt.Callback or function() end

            local SettingFrame = CreateBaseSetting(name, desc)
            SettingFrame.Parent = Contents

            local CheckboxButton = Instance.new("ImageButton")
            CheckboxButton.Name = "CheckboxButton"
            CheckboxButton.Size = UDim2.new(0.25, 0, 1, 0)
            CheckboxButton.Position = UDim2.new(0.875, 0, 0.5, 0)
            CheckboxButton.AnchorPoint = Vector2.new(0.5, 0.5)
            CheckboxButton.BackgroundTransparency = 1
            CheckboxButton.Image = "rbxassetid://18953971849"
            CheckboxButton.Parent = SettingFrame

            Instance.new("UIAspectRatioConstraint", CheckboxButton)

            local Checked = Instance.new("ImageLabel")
            Checked.Name = "Checked"
            Checked.Size = UDim2.new(0.75, 0, 0.75, 0)
            Checked.Position = UDim2.new(0.5, 0, 0.5, 0)
            Checked.AnchorPoint = Vector2.new(0.5, 0.5)
            Checked.BackgroundTransparency = 1
            Checked.Image = "rbxassetid://18953976521"
            Checked.ScaleType = Enum.ScaleType.Fit
            Checked.Visible = default
            Checked.ZIndex = 2
            Checked.Parent = CheckboxButton

            local state = default
            CheckboxButton.MouseButton1Click:Connect(function()
                state = not state
                Checked.Visible = state
                callback(state)
            end)
        end

        function Tab:Slider(opt)
            local name = opt.Title or "Slider"
            local desc = opt.Description or ""
            local min = opt.Min or 0
            local max = opt.Max or 100
            local default = opt.Default or min
            local callback = opt.Callback or function() end

            local SettingFrame = CreateBaseSetting(name, desc)
            SettingFrame.Parent = Contents

            local DragBarBackground = Instance.new("ImageLabel")
            DragBarBackground.Name = "DragBarBackground"
            DragBarBackground.Size = UDim2.new(0.5, 0, 0.725, 0)
            DragBarBackground.Position = UDim2.new(0.875, 0, 0.5, 0)
            DragBarBackground.AnchorPoint = Vector2.new(0.5, 0.5)
            DragBarBackground.BackgroundTransparency = 1
            DragBarBackground.Image = "rbxassetid://125225912214611"
            DragBarBackground.ImageColor3 = Color3.fromRGB(0, 0, 0)
            DragBarBackground.Parent = SettingFrame

            local DragBar = Instance.new("Frame")
            DragBar.Name = "DragBar"
            DragBar.Size = UDim2.new(0.4, 0, 0.725, 0)
            DragBar.Position = UDim2.new(0.875, 0, 0.5, 0)
            DragBar.AnchorPoint = Vector2.new(0.5, 0.5)
            DragBar.BackgroundTransparency = 1
            DragBar.Parent = SettingFrame

            local Dragger = Instance.new("ImageButton")
            Dragger.Name = "Dragger"
            Dragger.Size = UDim2.new(0.5, 0, 0.75, 0)
            Dragger.Position = UDim2.new(0.5, 0, 0.5, 0)
            Dragger.AnchorPoint = Vector2.new(0.5, 0.5)
            Dragger.BackgroundTransparency = 1
            Dragger.Image = "rbxassetid://130893928901265"
            Dragger.ImageColor3 = Color3.fromRGB(220, 220, 220)
            Dragger.Parent = DragBar
            Instance.new("UIAspectRatioConstraint", Dragger)

            local TitleLabel = Instance.new("TextLabel")
            TitleLabel.Name = "Title"
            TitleLabel.Size = UDim2.new(2, 0, 0.8, 0)
            TitleLabel.Position = UDim2.new(0.5, 0, 0, 0)
            TitleLabel.AnchorPoint = Vector2.new(0.5, 0.9)
            TitleLabel.BackgroundTransparency = 1
            TitleLabel.FontFace = CustomFont
            TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            TitleLabel.TextScaled = true
            TitleLabel.Text = tostring(default)
            TitleLabel.Parent = Dragger

            -- Slider Logic
            local dragging = false
            Dragger.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local mousePos = UserInputService:GetMouseLocation().X
                    local barAbsPos = DragBar.AbsolutePosition.X
                    local barAbsSize = DragBar.AbsoluteSize.X
                    
                    local percent = math.clamp((mousePos - barAbsPos) / barAbsSize, 0, 1)
                    local value = math.floor(min + ((max - min) * percent))
                    
                    Dragger.Position = UDim2.new(percent, 0, 0.5, 0)
                    TitleLabel.Text = tostring(value)
                    
                    callback(value)
                end
            end)

            local defaultPercent = math.clamp((default - min) / (max - min), 0, 1)
            Dragger.Position = UDim2.new(defaultPercent, 0, 0.5, 0)
        end

        function Tab:Textbox(opt)
            local name = opt.Title or "Textbox"
            local desc = opt.Description or ""
            local default = opt.Default or ""
            local callback = opt.Callback or function() end

            local SettingFrame = CreateBaseSetting(name, desc)
            SettingFrame.Parent = Contents

            local TextboxBackground = Instance.new("ImageLabel")
            TextboxBackground.Name = "TextboxBackground"
            TextboxBackground.Size = UDim2.new(0.4, 0, 0.8, 0)
            TextboxBackground.Position = UDim2.new(0.875, 0, 0.5, 0)
            TextboxBackground.AnchorPoint = Vector2.new(0.5, 0.5)
            TextboxBackground.BackgroundTransparency = 1
            TextboxBackground.Image = "rbxassetid://18954013854"
            TextboxBackground.Parent = SettingFrame

            local TextBox = Instance.new("TextBox")
            TextBox.Name = "Textbox"
            TextBox.Size = UDim2.new(0.85, 0, 0.5, 0)
            TextBox.Position = UDim2.new(0.5, 0, 0.52, 0)
            TextBox.AnchorPoint = Vector2.new(0.5, 0.5)
            TextBox.BackgroundTransparency = 1
            TextBox.FontFace = CustomFont
            TextBox.TextColor3 = Color3.fromRGB(255, 255, 255)
            TextBox.PlaceholderColor3 = Color3.fromRGB(255, 255, 255)
            TextBox.TextScaled = true
            TextBox.ClearTextOnFocus = false
            TextBox.PlaceholderText = "..."
            TextBox.Text = default
            TextBox.Parent = TextboxBackground

            TextBox.FocusLost:Connect(function()
                callback(TextBox.Text)
            end)
        end

        function Tab:Dropdown(opt)
            local name = opt.Title or "Dropdown"
            local desc = opt.Description or ""
            local optionsList = opt.Options or {}
            local default = opt.Default or "Select"
            local callback = opt.Callback or function() end

            local SettingFrame = CreateBaseSetting(name, desc)
            SettingFrame.Parent = Contents

            local DropdownFrame = Instance.new("ImageButton")
            DropdownFrame.Name = "DropdownFrame"
            DropdownFrame.Size = UDim2.new(0.35, 0, 1, 0)
            DropdownFrame.Position = UDim2.new(0.875, 0, 0.5, 0)
            DropdownFrame.AnchorPoint = Vector2.new(0.5, 0.5)
            DropdownFrame.BackgroundTransparency = 1
            DropdownFrame.Image = "rbxassetid://18954013854"
            DropdownFrame.ZIndex = 2
            DropdownFrame.Parent = SettingFrame

            local AR = Instance.new("UIAspectRatioConstraint")
            AR.AspectRatio = 4.3
            AR.Parent = DropdownFrame

            local DropdownArrow = Instance.new("ImageLabel")
            DropdownArrow.Name = "DropdownArrow"
            DropdownArrow.Size = UDim2.new(0.15, 0, 0.75, 0)
            DropdownArrow.Position = UDim2.new(0.07, 0, 0.5, 0)
            DropdownArrow.AnchorPoint = Vector2.new(0, 0.5)
            DropdownArrow.BackgroundTransparency = 1
            DropdownArrow.Image = "rbxassetid://18954016422"
            DropdownArrow.Parent = DropdownFrame

            local ChosenValue = Instance.new("ImageLabel")
            ChosenValue.Name = "ChosenValue"
            ChosenValue.Size = UDim2.new(0.656, 0, 0.75, 0)
            ChosenValue.Position = UDim2.new(0.272, 0, 0.153, 0)
            ChosenValue.BackgroundTransparency = 1
            ChosenValue.Image = "rbxassetid://18954024670"
            ChosenValue.Parent = DropdownFrame

            local TitleLabel = Instance.new("TextLabel")
            TitleLabel.Name = "Title"
            TitleLabel.Size = UDim2.new(0.7, 0, 0.7, 0)
            TitleLabel.Position = UDim2.new(0.5, 0, 0.143, 0)
            TitleLabel.AnchorPoint = Vector2.new(0.5, 0)
            TitleLabel.BackgroundTransparency = 1
            TitleLabel.FontFace = CustomFont
            TitleLabel.TextColor3 = Color3.fromRGB(0, 0, 0)
            TitleLabel.TextScaled = true
            TitleLabel.Text = default
            TitleLabel.Parent = ChosenValue

            local Options = Instance.new("Frame")
            Options.Name = "Options"
            Options.Size = UDim2.new(1, 0, 0, 0)
            Options.Position = UDim2.new(0.5, 0, 1, 0)
            Options.AnchorPoint = Vector2.new(0.5, 0)
            Options.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            Options.BackgroundTransparency = 0.5
            Options.BorderSizePixel = 0
            Options.AutomaticSize = Enum.AutomaticSize.Y
            Options.Visible = false
            Options.Parent = DropdownFrame

            Instance.new("UIListLayout", Options).SortOrder = Enum.SortOrder.LayoutOrder

            for _, optString in ipairs(optionsList) do
                local OptBtn = Instance.new("TextButton")
                OptBtn.Size = UDim2.new(1, 0, 0, 30)
                OptBtn.BackgroundTransparency = 1
                OptBtn.FontFace = CustomFont
                OptBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                OptBtn.TextScaled = true
                OptBtn.Text = optString
                OptBtn.Parent = Options

                OptBtn.MouseButton1Click:Connect(function()
                    TitleLabel.Text = optString
                    Options.Visible = false
                    callback(optString)
                end)
            end

            DropdownFrame.MouseButton1Click:Connect(function()
                Options.Visible = not Options.Visible
            end)
        end

        return Tab
    end

    return Window
end

return Library
